// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "format_on_save": "on",
  "languages": {
    "C": {
      "formatter": {
        "external": {
          "command": "clang-format",
          "arguments": [
            "--style={BasedOnStyle: LLVM, SpaceBeforeParens: Never}",
          ],
        },
      },
    },
    "C++": {
      "formatter": {
        "external": {
          "command": "clang-format",
          "arguments": [
            "--style={BasedOnStyle: LLVM, SpaceBeforeParens: Never}",
          ],
        },
      },
    },
  },
  "ssh_connections": [
    {
      "host": "ece337L",
      "args": [],
      "projects": [
        {
          "paths": ["/home/ecegridfs/a/337mg257/ece337"],
        },
        {
          "paths": ["/home/ecegridfs/a/337mg257/ece337/./"],
        },
        {
          "paths": [
            "/home/ecegridfs/a/337mg257/ece337/ECE337-CDL-Systolic-Array",
          ],
        },
      ],
    },
    {
      "host": "ece337R",
      "args": [],
      "projects": [
        {
          "paths": ["/home/ecegridfs/a/337mg257/ece337"],
        },
        {
          "paths": [
            "/home/ecegridfs/a/337mg257/ece337/ECE337-CDL-Systolic-Array/./",
          ],
        },
      ],
    },
  ],
  "edit_predictions": {
    "mode": "subtle",
    "provider": "zed",
  },
  "agent": {
    "dock": "right",
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "agent_servers": {
    "gemini": {
      "type": "registry",
    },
    "github-copilot": {
      "type": "registry",
    },
  },
  "disable_ai": false,
  "calls": {
    "share_on_join": true,
    "mute_on_join": true,
  },
  "tabs": {
    "git_status": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_sign_in": false,
    "show_menus": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "file_types": {
    "cpp": ["*.ino"],
    "java": ["*.java"],
  },
  "show_edit_predictions": false,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Tokyo Night",
  },
  "auto_install_extensions": {
    "tokyo-night": true,
    "astro": true,
    "rainbow-csv": true,
    "csv": true,
    "verilog": true,
    "git-firefly": true,
    "ruby": true,
    "make": true,
    "latex": true,
    "html": true,
  },
}
